{
  "cleanUrls": true,
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/tv$", "dest": "/index.html" },
    { "src": "^/settings$", "dest": "/index.html" },
    { "src": "^/apps/(.*)", "dest": "/public/apps/$1" },
    { "src": "^/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "^/(.*)", "dest": "/index.html" }
  ]
}
